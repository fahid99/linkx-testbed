# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Only the agent chain (agents.run_trial) needs these; the API and MCP
# servers never call a model provider directly.
ANTHROPIC_API_KEY=sk-ant-...

# Non-Anthropic models are selected as "provider:model" (see PROVIDERS in
# agents/chain.py). Only set the key(s) for the vendor(s) you're evaluating.
# KIMI_API_KEY=...
# KIMI_BASE_URL=https://api.moonshot.ai/v1   # https://api.moonshot.cn/v1 for the CN region
# GROQ_API_KEY=...
# OPENROUTER_API_KEY=...
# OPENAI_API_KEY=...
